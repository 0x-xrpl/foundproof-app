{
  "name": "foundproof",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "server": "node --import tsx server/index.ts",
    "server:watch": "tsx watch server/index.ts",
    "symbol:bootstrap:verify": "npx --yes symbol-bootstrap verify",
    "symbol:bootstrap:start": "npx --yes symbol-bootstrap start -p bootstrap -a demo",
    "symbol:bootstrap:stop": "npx --yes symbol-bootstrap stop",
    "symbol:bootstrap:clean": "npx --yes symbol-bootstrap clean",
    "symbol:network:profile": "node scripts/symbol-network-profile.mjs",
    "symbol:bootstrap:accounts": "node scripts/symbol-bootstrap-accounts.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "dotenv": "^17.2.3",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.10",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.8",
    "expo-location": "~19.0.0",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "0.21.0",
    "rxjs": "^7.8.1",
    "symbol-sdk": "^3.3.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^24.6.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5.7.0"
  }
}
