# Local API port for `npm run server`
PORT=8787

# Switch Expo to API-backed mode
EXPO_PUBLIC_DATA_MODE=api

# Base URL used by the Expo app for the local FoundProof API
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Public Symbol Testnet REST node used by the server-side proof anchor
SYMBOL_NODE_URL=https://sym-test-01.opening-line.jp:3001

# Keep this as TEST_NET for the FoundProof MVP
SYMBOL_NETWORK_TYPE=TEST_NET

# Optional. Leave empty unless your chosen infrastructure explicitly requires it.
SYMBOL_GENERATION_HASH=

# Required for real Symbol Testnet anchoring through server-side signing
SYMBOL_PRIVATE_KEY=PASTE_DEDICATED_TESTNET_SERVER_PRIVATE_KEY

# Optional operational reference value
SYMBOL_PUBLIC_KEY=OPTIONAL_SERVER_PUBLIC_KEY

# Small fee multiplier is sufficient for the MVP
SYMBOL_MAX_FEE=100

# Prefix stored in the Symbol transfer message payload
SYMBOL_MESSAGE_PREFIX=FOUNDPROOF:

# Future payment adapters remain disabled
EXPO_PUBLIC_GRATITUDE_PAYMENTS_ENABLED=false
EXPO_PUBLIC_GRATITUDE_PAYMENT_ADAPTER=none
