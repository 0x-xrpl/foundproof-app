# Local API port for `npm run server`
PORT=8787

# Private bootstrap network still uses the API-backed flow
EXPO_PUBLIC_DATA_MODE=api
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Local Symbol Bootstrap REST node and explorer
SYMBOL_NODE_URL=http://127.0.0.1:3000
SYMBOL_EXPLORER_BASE_URL=http://127.0.0.1:90
EXPO_PUBLIC_SYMBOL_EXPLORER_BASE_URL=http://127.0.0.1:90

# Symbol Bootstrap local private test networks created with preset `bootstrap`
# typically use TEST_NET semantics, but with a different generation hash.
SYMBOL_NETWORK_TYPE=TEST_NET

# Fill these from `npm run symbol:network:profile -- http://127.0.0.1:3000`
SYMBOL_GENERATION_HASH=REPLACE_WITH_LOCAL_GENERATION_HASH
SYMBOL_EPOCH_ADJUSTMENT_SECONDS=REPLACE_WITH_LOCAL_EPOCH_ADJUSTMENT_SECONDS

# Use a funded private-network account from `target/addresses.yml`
# or from `npm run symbol:bootstrap:accounts`
SYMBOL_PRIVATE_KEY=REPLACE_WITH_BOOTSTRAP_ACCOUNT_PRIVATE_KEY
SYMBOL_PUBLIC_KEY=REPLACE_WITH_BOOTSTRAP_ACCOUNT_PUBLIC_KEY

SYMBOL_MAX_FEE=100
SYMBOL_MESSAGE_PREFIX=FOUNDPROOF:

# Future payment adapters remain disabled
EXPO_PUBLIC_GRATITUDE_PAYMENTS_ENABLED=false
EXPO_PUBLIC_GRATITUDE_PAYMENT_ADAPTER=none
