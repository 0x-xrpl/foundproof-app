# Local API port for `npm run server`
PORT=8787

# `mock` keeps the Expo app fully usable without the API or Symbol wallet.
# Switch to `api` only after the local API is running and Symbol Testnet env is ready.
EXPO_PUBLIC_DATA_MODE=mock

# Base URL used by the Expo app when EXPO_PUBLIC_DATA_MODE=api
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Public Symbol Testnet REST node used by the server-side anchor flow
SYMBOL_NODE_URL=https://sym-test-01.opening-line.jp:3001

# Keep this as TEST_NET for FoundProof MVP
SYMBOL_NETWORK_TYPE=TEST_NET

# Optional. Leave empty unless your chosen node setup requires an explicit generation hash.
SYMBOL_GENERATION_HASH=

# Required for real anchoring. Put the private key of the dedicated FoundProof Testnet server wallet.
# Do not use a personal main wallet here.
SYMBOL_PRIVATE_KEY=REPLACE_WITH_TESTNET_PRIVATE_KEY

# Optional reference value. Not used by the current server code, but useful for verification and ops notes.
SYMBOL_PUBLIC_KEY=

# Fee multiplier for the transfer transaction. Keep a small testnet value unless you have a reason to change it.
SYMBOL_MAX_FEE=100

# Message prefix stored in the Symbol transfer message payload
SYMBOL_MESSAGE_PREFIX=FOUNDPROOF:

# Future optional gratitude-payment extension point.
# Keep disabled in the current MVP.
EXPO_PUBLIC_GRATITUDE_PAYMENTS_ENABLED=false
EXPO_PUBLIC_GRATITUDE_PAYMENT_ADAPTER=none
